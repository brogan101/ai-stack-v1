{
  "name": "local-ai",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "pnpm --filter api-server dev",
    "dev:ui": "pnpm --filter localai-control-center dev",
    "start:api": "pnpm --filter api-server start",
    "build": "pnpm -r --filter=!@workspace/api-spec build",
    "typecheck": "pnpm -r --filter=!@workspace/api-spec typecheck",
    "install:all": "pnpm install"
  },
  "pnpm": {
    "overrides": {}
  }
}
